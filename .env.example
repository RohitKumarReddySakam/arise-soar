# SENTINEL SOAR - Environment Variables
# Copy this file to .env and fill in your values

SECRET_KEY=your-super-secret-key-change-this-in-production

# Database (leave as SQLite for local dev, use PostgreSQL for production)
DATABASE_URL=sqlite:///sentinel_soar.db
# DATABASE_URL=postgresql://user:password@localhost:5432/sentinel_soar

# Demo Mode (generates background alerts automatically)
DEMO_MODE=true

# Threat Intelligence API Keys (optional - enables real enrichment)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=

# Notifications (optional)
SLACK_WEBHOOK_URL=
